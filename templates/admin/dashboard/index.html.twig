{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <section class="dashboard-card">
        <div class="page-header">
            <div>
                <h1>Dashboard</h1>
                <p>Vue globale de l’application SHOGGA.</p>
            </div>
        </div>

        <div class="stats-grid">
            <article class="stat-card">
                <span class="stat-label">Logs analysés</span>
                <strong class="stat-value">{{ logStats.total }}</strong>
            </article>

            <article class="stat-card stat-card-error">
                <span class="stat-label">Erreurs</span>
                <strong class="stat-value">{{ logStats.errors }}</strong>
            </article>

            <article class="stat-card stat-card-warning">
                <span class="stat-label">Warnings</span>
                <strong class="stat-value">{{ logStats.warnings }}</strong>
            </article>

            <article class="stat-card">
                <span class="stat-label">Infos</span>
                <strong class="stat-value">{{ logStats.infos }}</strong>
            </article>
        </div>
    </section>
    <section class="dashboard-card">
        <h2>Santé système</h2>

        <div class="system-health-grid">
            <div>
                Application :
                {{ systemHealth.applicationOk ? '✅' : '❌' }}
            </div>

            <div>
                SQLite :
                {{ systemHealth.databaseOk ? '✅' : '❌' }}
            </div>

            <div>
                Logs :
                {{ systemHealth.logsDirectoryOk ? '✅' : '❌' }}
            </div>

            <div>
                Dernière maintenance :
                {{ systemHealth.lastMaintenanceDate ?: 'Jamais exécutée' }}
            </div>
        </div>
    </section>
    <section class="dashboard-card">
        <h2>Protection anti-spam</h2>

        <div class="stats-grid">
            <article class="stat-card">
                <span class="stat-label">Blocages RateLimiter</span>
                <strong class="stat-value">{{ rateLimiterStats.blockedCount }}</strong>
            </article>

            <article class="stat-card">
                <span class="stat-label">Dernière IP bloquée</span>
                <strong class="stat-value stat-value-small">
                    {{ rateLimiterStats.lastBlockedIp ?: 'Aucune' }}
                </strong>
            </article>

            <article class="stat-card">
                <span class="stat-label">Dernier endpoint bloqué</span>
                <strong class="stat-value stat-value-small">
                    {{ rateLimiterStats.lastBlockedPath ?: 'Aucun' }}
                </strong>
            </article>

            <article class="stat-card">
                <span class="stat-label">Dernier blocage</span>
                <strong class="stat-value stat-value-small">
                    {{ rateLimiterStats.lastBlockedDate ?: 'Aucun' }}
                </strong>
            </article>
        </div>
    </section>
{% endblock %}